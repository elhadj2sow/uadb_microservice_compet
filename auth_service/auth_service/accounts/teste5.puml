@startuml DCU_06_Notification
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle

actor "Étudiant"         as ETU
actor "Administrateur"   as ADM
actor "Système / Services" as SYS <<system>>

rectangle "notification_service — Notifications & Chatbot" {
  usecase "Consulter ses notifications"         as UC01
  usecase "Marquer une notification comme lue"  as UC02
  usecase "Envoyer un message au chatbot"       as UC03
  usecase "Consulter historique conversations"  as UC04

  usecase "Envoyer une notification"            as UC05
  usecase "Relancer envois échoués"             as UC06
  usecase "Consulter toutes les notifications"  as UC07
  usecase "Gérer base de connaissances chatbot" as UC08
  usecase "Consulter statistiques d'envoi"      as UC09

  usecase "Résoudre adresse email (auth)"       as UC10
  usecase "Envoyer email SMTP"                  as UC11
  usecase "Détecter intention (NLP)"            as UC12
  usecase "Retourner réponse chatbot"           as UC13
}

ETU --> UC01
ETU --> UC02
ETU --> UC03
ETU --> UC04

ADM --> UC06
ADM --> UC07
ADM --> UC08
ADM --> UC09

SYS --> UC05

UC05 ..> UC10 : <<include>>
UC05 ..> UC11 : <<include>>
UC03 ..> UC12 : <<include>>
UC12 ..> UC13 : <<include>>
UC06 ..> UC11 : <<include>>
@enduml