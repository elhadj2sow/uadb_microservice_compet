    {
      "name": "2 - Dossier Service",
      "item": [
        {
          "name": "Lister Formations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_etudiant}}" }
            ],
            "url": "{{DOSSIER_URL}}/api/formations/"
          }
        },
        {
          "name": "Creer Dossier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 400 (already exists)', function () { pm.expect([201,400]).to.include(pm.response.code); });",
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('dossier_id', String(json.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_etudiant}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"formation\": {{formation_id}},\n  \"annee_universitaire\": \"{{annee_universitaire}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{DOSSIER_URL}}/api/dossiers/"
          }
        },
        {
          "name": "Mon Dossier",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_etudiant}}" }
            ],
            "url": "{{DOSSIER_URL}}/api/dossiers/mon-dossier/?annee={{annee_universitaire}}"
          }
        },
        {
          "name": "Deposer Piece (form-data)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('piece_id', String(json.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_etudiant}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type_piece", "value": "{{piece_type}}", "type": "text" },
                { "key": "fichier", "type": "file", "src": "" },
                { "key": "est_obligatoire", "value": "true", "type": "text" }
              ]
            },
            "url": "{{DOSSIER_URL}}/api/dossiers/{{dossier_id}}/pieces/"
          }
        },
        {
          "name": "Verifier Piece (Agent Scolarite)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_scolarite}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"valider\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{DOSSIER_URL}}/api/pieces/{{piece_id}}/verifier/"
          }
        },
        {
          "name": "Valider Dossier (Agent Scolarite)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_scolarite}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"etat_dossier\": \"valide\",\n  \"observation\": \"Dossier administratif valide\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{DOSSIER_URL}}/api/dossiers/{{dossier_id}}/"
          }
        }
      ]
