        {
          "name": "Auth Login Ping",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{student_username}}\",\n  \"password\": \"{{student_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{AUTH_URL}}/api/auth/login/"
          }
        },
        {
          "name": "Dossier Formations Ping",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_etudiant}}" }
            ],
            "url": "{{DOSSIER_URL}}/api/formations/"
          }
        }
      ]
    },
