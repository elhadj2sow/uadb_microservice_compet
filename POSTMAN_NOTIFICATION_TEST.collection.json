            "value": "Bearer {{service_notification_access_token}}"
          }
        ],
        "url": {
          "raw": "{{notification_base_url}}/api/notifications/admin/relancer/",
          "host": [
            "{{notification_base_url}}"
          ],
          "path": [
            "api",
            "notifications",
            "admin",
            "relancer",
            ""
          ]
        }
      }
    },
    {
      "name": "Notification - Statistiques",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{service_notification_access_token}}"
          }
        ],
        "url": {
          "raw": "{{notification_base_url}}/api/notifications/statistiques/",
          "host": [
            "{{notification_base_url}}"
          ],
